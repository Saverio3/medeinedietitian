# ============================================================================
# Environment variables
# ============================================================================
# Copy this file to .env.local for local development, and set these same
# variables in Vercel's dashboard (Project Settings → Environment Variables)
# for production.
# ============================================================================


# ---- Resend — contact form email delivery (REQUIRED for contact form) ----
# Sign up free at https://resend.com
# Free tier: 100 emails/day, 3,000/month.
# Steps:
#   1. Create a Resend account
#   2. Create an API key at https://resend.com/api-keys
#   3. Paste it below (starts with "re_")
RESEND_API_KEY=re_your_key_here

# Sender identity shown in the "From" field when emails arrive.
# Default works out of the box using Resend's sandbox domain.
# Once you verify your real domain in Resend, change this to:
#   RESEND_FROM="Medeinė Deginaitė <hello@medeinedietitian.co.uk>"
RESEND_FROM="Website <onboarding@resend.dev>"


# ============================================================================
# OPTIONAL
# ============================================================================

# If you add Plausible Analytics later instead of Vercel Analytics,
# set the domain here and Plausible will load.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=medeinedietitian.co.uk
